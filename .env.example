# ==========================================
# GATEKEEPER LIVE PIPELINE - CREDENCIAIS
# ==========================================

# 1. LLM API (Cérebro da Operação - Prompt V25)
# --- Opção A: OpenAI (pago) ---
# LLM_API_KEY="sk-proj-sua-chave-openai-aqui"
# LLM_BASE_URL=""         # vazio = usa api.openai.com por padrão
# LLM_MODEL=""            # vazio = gpt-4o-mini

# --- Opção B: Groq (GRATUITO — recomendado) ---
# Cadastro: https://console.groq.com/  →  Chaves em: API Keys
LLM_API_KEY="gsk_sua-chave-groq-aqui"
LLM_BASE_URL="https://api.groq.com/openai/v1"
LLM_MODEL="llama-3.3-70b-versatile"

# --- Opção C: Google Gemini (GRATUITO) ---
# Cadastro: https://aistudio.google.com/  →  Chaves em: Get API Key
# LLM_API_KEY="AIza-sua-chave-gemini-aqui"
# LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# LLM_MODEL="gemini-2.0-flash"

# --- Fallback automático (ativado quando o provedor principal retorna HTTP 429) ---
# Se LLM_FALLBACK_API_KEY estiver definida, o sistema tenta este provedor
# automaticamente antes de desistir.  Exemplo: Groq primário → Gemini fallback.
# LLM_FALLBACK_API_KEY="AIza-sua-chave-gemini-aqui"
# LLM_FALLBACK_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# LLM_FALLBACK_MODEL="gemini-2.0-flash"

# (Compatibilidade legada — também funciona se definido)
# OPENAI_API_KEY="sk-proj-sua-chave-openai-aqui"

# 2. Dados Esportivos / Escalações T-60 (Ex: API-Football ou Sportmonks)
API_FOOTBALL_KEY="sua-chave-api-football-aqui"

# 3. Superbet Shadow Mode (Coleta de Odds)
SUPERBET_API_TOKEN="seu-token-de-sessao-ou-api-aqui"
SUPERBET_USERNAME="seu-email@exemplo.com"
SUPERBET_PASSWORD="sua-senha-superbet"
